# PostgreSQL Connection Database URL
DATABASE_URL=sqlite:///./claims.db

# Qdrant Vector DB Service URL
QDRANT_URL=http://localhost:6333

# Google Gemini API Developer Key (Get it from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# Model settings
MODEL_PROVIDER=google
MODEL_NAME=gemini-2.5-flash

# LangSmith Observability Tracing settings
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_PROJECT=insurance-claims-processing

